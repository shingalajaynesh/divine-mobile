# Divine mobile environment example
# EXPO_PUBLIC_* values are compiled into app bundles. Use public client values only.

# Firebase mobile client configuration
EXPO_PUBLIC_FIREBASE_API_KEY=<firebase_mobile_api_key>
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=<firebase_auth_domain>
EXPO_PUBLIC_FIREBASE_PROJECT_ID=<firebase_project_id>
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=<firebase_storage_bucket>
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<firebase_messaging_sender_id>
EXPO_PUBLIC_FIREBASE_APP_ID=<firebase_mobile_app_id>

# Public API configuration
EXPO_PUBLIC_GRAPHQL_API_URL=http://your_local_ip_address:4000/graphql
