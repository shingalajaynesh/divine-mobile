{
  "expo": {
    "name": "Divine Garbh Sanskar",
    "slug": "divine-mobile",
    "version": "1.1.0",
    "scheme": "divinemobile",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFBE8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.divinegarbhsanskar.app"
    },
    "android": {
      "package": "com.divinegarbhsanskar.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFBE8"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "bd6e3284-5ff1-4ecc-a0c1-3109b725812c"
      }
    }
  }
}
